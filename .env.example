# ---------------------------------------------------------------------------
# webinar-auto-registration — environment variables
# Copy to `.env` for local runs, or add each as a GitHub Actions Secret.
# ---------------------------------------------------------------------------

# --- Google Calendar (OAuth refresh-token flow) -----------------------------
# Create an OAuth 2.0 "Desktop app" client in Google Cloud Console, then run
#   python scripts/get_google_token.py
# to mint the refresh token.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# Target calendar id ("primary" for your main Gmail calendar, or a calendar id)
GOOGLE_CALENDAR_ID=primary

# --- Per-site login credentials --------------------------------------------
# Only needed for sites where auto login/registration is enabled in
# config/sites.yaml. Leave blank to skip that site's registration.
SITE_ALLSHOWTV_USER=
SITE_ALLSHOWTV_PASS=
SITE_SHAREDIT_USER=
SITE_SHAREDIT_PASS=
SITE_DDTUBE_USER=
SITE_DDTUBE_PASS=
SITE_E4DS_USER=
SITE_E4DS_PASS=
SITE_TALKIT_USER=
SITE_TALKIT_PASS=
SITE_DUBIZ_USER=
SITE_DUBIZ_PASS=
SITE_CLOIT_USER=
SITE_CLOIT_PASS=
